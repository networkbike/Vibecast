# VibeCast environment variables
# Copy this file to .env and fill in real values

# Port the API listens on (Render sets this automatically)
PORT=3000

# LLM provider (we use OpenAI by default; swap for any OpenAI-compatible API)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# x402 / OKX Payment SDK config
# Your X Layer wallet address that receives USDT0 payments
RECEIVE_ADDRESS=0xYourXLayerWalletAddressHere

# Settlement token (USDT0 on X Layer)
# This is the official USDT0 contract on X Layer — DO NOT change
USDT0_TOKEN_ADDRESS=0x779ded0c9e1022225f8e0630b35a9b54be713736

# Network (X Layer mainnet = eip155:196)
X402_NETWORK=eip155:196

# Pricing (in USDT0, 6 decimals)
# Free tier: 3 calls per IP per day
FREE_TIER_DAILY=3
# Paid price per call: 5000 = $0.005
PAID_PRICE_MIN_UNITS=5000

# YouTube Data API v3 key (bypasses transcript scraping rate limits)
# Get a free key at https://console.cloud.google.com/ — enable YouTube Data API v3, create API key.
# Free tier is 10,000 units/day; each call costs 1 unit. Bypasses the IP-based rate limit
# that affects Render's shared IPs.
YT_API_KEY=AIza...

# Supadata API key (RECOMMENDED — easier signup, returns full transcripts)
# Get a free key at https://supadata.ai — 100 free requests/month, no credit card.
# Handles YouTube scraping on their own infrastructure, so we never hit rate limits.
SUPADATA_API_KEY=sd_...

# Legacy: external transcript proxy (kept for backward compat)
YT_PROXY_URL=https://vibecast-yt-proxy.onrender.com

# Optional: rate limiting
RATE_LIMIT_WINDOW_MS=86400000
RATE_LIMIT_MAX=100
